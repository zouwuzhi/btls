 // Compliance policy configurations
diff --git a/ssl/internal.h b/ssl/internal.h
index a69505b47..b2c1f3a94 100644
--- a/ssl/internal.h
+++ b/ssl/internal.h
@@ -464,6 +464,8 @@ class SSLTranscript {
   // enabled. It returns true on success and false on failure.
   bool Update(Span<const uint8_t> in);
 
+  uint8_t *BufferData();
+  size_t BufferLen() const;
   // GetHash writes the handshake hash to |out| which must have room for at
   // least |DigestLen| bytes. On success, it returns true and sets |*out_len| to
   // the number of bytes written. Otherwise, it returns false.
diff --git a/ssl/ssl_lib.cc b/ssl/ssl_lib.cc
index f64b103fb..00127f21f 100644
--- a/ssl/ssl_lib.cc
+++ b/ssl/ssl_lib.cc
@@ -3538,3 +3538,50 @@ int SSL_set1_requested_trust_anchors(SSL *ssl, const uint8_t *ids,
 }
 
 int SSL_CTX_get_security_level(const SSL_CTX *ctx) { return 0; }
+
+int SSL_get_x25519_private_key(const SSL *ssl, uint8_t *out, size_t *out_len) {
+  if (!ssl || !ssl->s3 || !ssl->s3->hs) {
+    return 0;
+  }
+  for (const auto &key_share : ssl->s3->hs->key_shares) {
+    if (key_share->GroupID() == SSL_GROUP_X25519) {
+      CBB cbb;
+      if (!CBB_init(&cbb, 32) ||
+          !key_share->SerializePrivateKey(&cbb)) {
+        CBB_cleanup(&cbb);
+        return 0;
+      }
+      size_t len;
+      uint8_t *data;
+      if (!CBB_finish(&cbb, &data, &len)) {
+        CBB_cleanup(&cbb);
+        return 0;
+      }
+      if (len != 32) {
+        OPENSSL_free(data);
+        return 0;
+      }
+      OPENSSL_memcpy(out, data, 32);
+      *out_len = 32;
+      OPENSSL_free(data);
+      return 1;
+    }
+  }
+  return 0;
+}
+
+int SSL_set_client_hello_session_id(SSL *ssl, const uint8_t *sid,
+                                     size_t sid_len) {
+  if (!ssl || !ssl->s3 || !ssl->s3->hs || sid_len != 32) {
+    return 0;
+  }
+  auto *buf = ssl->s3->hs->transcript.BufferData();
+  size_t buf_len = ssl->s3->hs->transcript.BufferLen();
+  if (!buf || buf_len < 71 || buf[38] != 32) {
+    return 0;
+  }
+  OPENSSL_memcpy(buf + 39, sid, 32);
+  ssl->s3->hs->session_id.TryCopyFrom(
+      bssl::MakeConstSpan(sid, sid_len));
+  return 1;
+}
